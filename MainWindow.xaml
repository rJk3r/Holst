<Window x:Class="Holst.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewmodels="clr-namespace:Holst.ViewModels"
        xmlns:views="clr-namespace:Holst.Views"
        xmlns:models="clr-namespace:Holst"
        mc:Ignorable="d"
        Title="MainWindow" 
        MinHeight="600" 
        MinWidth="900" 
        Background="#111111" 
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        AllowsTransparency="True" MouseLeftButtonDown="MoveWindow">
    <Grid>
        
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ContentControl Content="{Binding CurrentViewModel}" Grid.Row="1">
            <ContentControl.Resources>
                <DataTemplate DataType="{x:Type viewmodels:HomeViewModel}">
                    <views:HomeView />
                </DataTemplate>

                <DataTemplate DataType="{x:Type viewmodels:AccountViewModel}">
                    <views:AccountView />
                </DataTemplate>

            </ContentControl.Resources>
        </ContentControl>
        <views:TitleBarView Grid.Row="0" x:Name="GeneralTitleBar" MinWidth="900" MinHeight="36" Background="#111111"/>
    </Grid>
</Window>
