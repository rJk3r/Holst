<UserControl x:Class="Holst.UserControls.HubNavigator"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Holst.UserControls"
             mc:Ignorable="d" 
             Width="130" MinHeight="600">
    <StackPanel>
        <Button Style="{StaticResource HubNavBtn}">
            <Path Width="55" Height="55" Style="{StaticResource ProfileIcon}" VerticalAlignment="Center" HorizontalAlignment="Center" Stretch="Uniform"/>
        </Button>
        <Button Style="{StaticResource HubNavBtn}">
            <Path Width="55" Height="55" Style="{StaticResource HomeIcon}" VerticalAlignment="Center" HorizontalAlignment="Center" Stretch="Fill"/>
        </Button>
        <Button Style="{StaticResource HubNavBtn}">
            <Path Width="50" Height="55" Style="{StaticResource CreateProjectIcon}" VerticalAlignment="Center" HorizontalAlignment="Center" Stretch="Fill"/>
        </Button>
        <Button Style="{StaticResource HubNavBtn}">
            <Path Width="55" Height="55" Style="{StaticResource SettingsIcon}" VerticalAlignment="Center" HorizontalAlignment="Center" Stretch="Fill"/>
        </Button>
    </StackPanel>
</UserControl>
