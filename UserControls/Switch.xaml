<UserControl x:Class="Holst.UserControls.Authentication.Switch"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Holst.UserControls.Authentication"
             mc:Ignorable="d"
             MaxHeight="47" MinWidth="336" MinHeight="47" MaxWidth="336">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Rectangle Stroke="#4C4C4C" StrokeThickness="0.2" RadiusX="9" RadiusY="9" Grid.ColumnSpan="2"/>
        <Button Content="Вход" Style="{StaticResource PrimaryButton}" Width="144" Height="39" Grid.Column="0" Margin="0,0,1,0"/>
        <Button x:Name="RegisterBtn" Style="{StaticResource Button}" Content="Регистрация" Width="144" Height="39" Grid.Column="1" Margin="1,0,0,0"/>
    </Grid>
</UserControl>
