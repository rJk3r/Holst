<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Rainbow color palette -->

    <SolidColorBrush x:Key="Red" Color="#FE4141"/>
    <SolidColorBrush x:Key="Orange" Color="#FF6D3B"/>
    <SolidColorBrush x:Key="Yellow" Color="#FBDA1C"/>
    <SolidColorBrush x:Key="Green" Color="#AEEB78"/>
    <SolidColorBrush x:Key="AquaBlue" Color="#78EBEB"/>
    <SolidColorBrush x:Key="Blue" Color="#6395F2"/>
    <SolidColorBrush x:Key="Purple" Color="#AF60FA"/>
    <SolidColorBrush x:Key="Magenta" Color="#FD3FA7"/>

    <!-- DarkModeBackGrounds -->

    <SolidColorBrush x:Key="BG" Color="#111111"/>
    <SolidColorBrush x:Key="BG1" Color="#252525"/>
    <SolidColorBrush x:Key="BG2" Color="#424242"/>

    <!-- Service colors -->
    <SolidColorBrush x:Key="LightWhite" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="White" Color="#D9D9D9"/>



</ResourceDictionary>